# Infrastructure
MONGODB_URI=mongodb://sentinel:sentinel_secret@mongodb:27017/iot-sentinel?authSource=admin
REDIS_URL=redis://redis:6379

# MongoDB root credentials (used by mongo container on first boot)
MONGO_INITDB_ROOT_USERNAME=sentinel
MONGO_INITDB_ROOT_PASSWORD=sentinel_secret

# Host ports (non-standard defaults to avoid conflicts with local services)
MONGO_PORT=9017
REDIS_PORT=9079
FRONTEND_PORT=9000
API_PORT=9001

# API
FRONTEND_URL=http://localhost:9000
# IMPORTANT: Change JWT_SECRET in production!
JWT_SECRET=change-me-in-production-please
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:9001

# Scanner Worker
SCANNER_MOCK_MODE=false
